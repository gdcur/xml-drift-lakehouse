# xml-drift-lakehouse — environment configuration
# Copy this file to .env and fill in your values:
#   cp docker/.env.example docker/.env

# ── Airflow core ───────────────────────────────────────────────────────────────
AIRFLOW_UID=1000
AIRFLOW_GID=0
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=false
AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=true
AIRFLOW__CORE__MAX_ACTIVE_RUNS_PER_DAG=1

# ── Webserver ──────────────────────────────────────────────────────────────────
AIRFLOW__WEBSERVER__EXPOSE_CONFIG=true
AIRFLOW__WEBSERVER__WARN_DEPLOYMENT_EXPOSURE=false

# ── Database ───────────────────────────────────────────────────────────────────
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres/airflow

# ── Logging ────────────────────────────────────────────────────────────────────
AIRFLOW__LOGGING__LOGGING_LEVEL=INFO

# ── Project paths ──────────────────────────────────────────────────────────────
DBT_PARQUET_PATH=/opt/project/output
DBT_PROJECT_DIR=/opt/project/dbt

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Two providers supported. Choose one and configure the relevant section below.
#
# Option A: Ollama (free, local, no API key needed)
#   - Install Ollama: https://ollama.ai
#   - Pull a model:   ollama pull llama3.1
#   - Ollama runs on your host machine, not inside Docker
#
# Option B: Claude API (better mapping quality, costs fractions of a cent per run)
#   - Get your API key: https://console.anthropic.com
#   - Only fires when schema drift is detected — not on every run
#
LLM_PROVIDER=ollama

# ── Ollama (if LLM_PROVIDER=ollama) ───────────────────────────────────────────
OLLAMA_MODEL=llama3.1        # any model you have pulled works
# Mac/Windows:
# OLLAMA_HOST=http://host.docker.internal:11434
# Linux:
OLLAMA_HOST=http://172.17.0.1:11434

# ── Claude API (if LLM_PROVIDER=claude) ───────────────────────────────────────
# Uncomment and set your key, then change LLM_PROVIDER=claude above
# ANTHROPIC_API_KEY=your-api-key-here

# ── Confidence thresholds (optional) ──────────────────────────────────────────
CONFIDENCE_AUTO=0.90
CONFIDENCE_REVIEW=0.70